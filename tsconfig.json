{
  "compilerOptions": {
    "allowJs": true,
    "target": "ES2019",
    "lib": ["ES2019"],
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "**/__tests__/*"]
}
